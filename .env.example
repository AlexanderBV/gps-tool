# ──────────────────────────────────────────────────────────────
# GPS Simulator — Variables de entorno
# Copia este archivo a .env y ajusta los valores para tu entorno.
# El archivo .env nunca se sube al repositorio.
# ──────────────────────────────────────────────────────────────

# URL completa del endpoint GPS (incluye la ruta, p. ej. /api/gps-tracker)
# Este valor actúa como fallback si el usuario no ha guardado configuración
# en el navegador desde el modal ⚙.
VITE_GPS_API_URL=http://gps-api.test/api/gps-tracker

# Bearer token de autenticación (fallback, igual que la URL)
VITE_GPS_API_TOKEN=

# ── SOLO DESARROLLO ────────────────────────────────────────────
# Proxy de Vite para evitar errores CORS en el navegador.
# Apunta al ORIGIN de la API (sin ruta). Cuando esta variable está
# presente, las peticiones que vayan a ese origin se redirigen
# automáticamente a través del servidor de Vite, sin que tengas
# que cambiar la URL en el modal de configuración.
#
# Ejemplo (API local con Laravel Valet/Herd):
VITE_GPS_DEV_PROXY=http://gps-api.test
#
# Si la API ya tiene CORS configurado o es un servidor remoto HTTPS,
# puedes dejar esta línea comentada.
